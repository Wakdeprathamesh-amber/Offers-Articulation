# Copy this file to .env and fill in the values you need. .env is gitignored.

# ---- OpenAI (required) ----
OPENAI_API_KEY=sk-your-key-here
# Optional: override the model (production uses gpt-5.5)
# OPENAI_MODEL=gpt-5.5
# OPENAI_TIMEOUT=60

# ---- Run-logging (optional) ----
# Pick ONE backend. If neither is configured, logging is silently disabled and
# generation still works. Google Sheets is preferred when both are set.

# Option A: Google Sheets (reachable from Render). Share the sheet with the
# service-account's client_email (Editor). Locally, point to the JSON file:
# GOOGLE_SHEET_ID=your-spreadsheet-id-from-the-url
# GOOGLE_SHEETS_CREDENTIALS_FILE=google-credentials.json
# GOOGLE_SHEETS_WORKSHEET=runs
# On Render (no files) paste the whole JSON into one env var instead of the file:
# GOOGLE_SHEETS_CREDENTIALS_JSON={"type":"service_account", ...}

# Option B: PostgreSQL (only works where the DB host is reachable, e.g. inside
# amber's network; the staging host is a private IP not reachable from Render).
# WAKDE_DB_HOST=db.staging-amber.com
# WAKDE_DB_PORT=5432
# WAKDE_DB_NAME=amber_graph
# WAKDE_DB_USER=
# WAKDE_DB_PASSWORD=
# WAKDE_DB_SSLMODE=prefer
